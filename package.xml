    <version>0.7.0-alpha</version>
    <date>2026-04-03</date>
    <maintainer email="alfred@mickautsch.de">Alfred Mickautsch</maintainer>
    <license file="LICENSE-CODE">LGPL-2.1</license>
    <license file="LICENSE-ICON">CC0-1.0</license>
    <icon>resources/icons/freecad_ai.svg</icon>
    <url type="repository" branch="master">https://github.com/ghbalf/freecad-ai</url>
    <url type="bugtracker">https://github.com/ghbalf/freecad-ai/issues</url>
    <url type="readme">https://github.com/ghbalf/freecad-ai/blob/master/Resources/Documents/Overview.md</url>
    <tag>AI</tag>
    <tag>LLM</tag>
    <tag>assistant</tag>
    <tag>modeling</tag>
    <tag>code generation</tag>
    <content>
        <workbench>
            <classname>FreeCADAIWorkbench</classname>
            <subdirectory>./</subdirectory>
        </workbench>
    </content>
    <depend type="internal">FreeCAD</depend>
    <freecadmin>1.0</freecadmin>
    <pythonmin>3.10</pythonmin>
</package>
